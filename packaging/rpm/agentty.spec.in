Name:           agentty
Version:        @VERSION@
Release:        1%{?dist}
Summary:        Blazing-fast Claude in your terminal
License:        MIT
URL:            https://github.com/1ay1/agentty
Source0:        agentty-linux-@RPM_ARCH@
ExclusiveArch:  @RPM_ARCH@

# This single .rpm serves every rpm-based distro: dnf (Fedora), yum (CentOS/RHEL),
# and zypper (openSUSE) all install it unchanged — `zypper install agentty`.

Recommends:     bubblewrap
Recommends:     openssh-clients

%description
agentty is a single-binary terminal client for Anthropic's Claude,
written in C++26. Sub-millisecond cold start, sandboxed shell calls
by default (via bubblewrap), and one-command SSH airgap for running
the agent on hosts without direct internet access.

Drop-in alternative to claude-code with no Node, Python, or Electron
runtime. Bring your own model: any provider API key, a local Ollama model,
or Claude Pro/Max OAuth.

%global debug_package %{nil}
%global __strip /bin/true

%prep
# Source is a pre-built static binary; nothing to unpack.

%install
install -Dm755 %{SOURCE0} %{buildroot}%{_bindir}/agentty

%files
%{_bindir}/agentty

%changelog
* @DATE@ Ayush Bhat <tfeayush@gmail.com> - @VERSION@-1
- Packaged from upstream release binaries.
